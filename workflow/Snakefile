# TODO: Add rules to generate PCA and correlation plots using R scripts
#PCA plot   
# This rule will generate a PCA plot using the count matrix and sample metadata. 
# The PCA plot will help visualize the overall structure of the data and identify any potential batch effects or outliers among the samples.
rule ea_plot_pca:
    input:
        counts= "../results/counts/count_matrix.tsv",
        metadata="../config/samples.tsv"
    output:
        "../results/analysis/pca_plot.pdf"
    log:
        "../logs/plot_pca.log"
    script:
        "scripts/plot_pca.R"

#corelation plot
# This rule will generate a correlation heatmap using the count matrix and sample metadata. 
# The correlation heatmap will show the pairwise correlations between samples based on their gene expression profiles.        
rule ea_plot_correlation:
    input:
        counts= "../results/counts/count_matrix.tsv",
        metadata="../config/samples.tsv"
    output:
        "../results/analysis/correlation_heatmap.pdf"
    log:
        "../logs/plot_correlation.log"
    script:
        "scripts/plot_correlation.R"


# TASK 6: DESeq2 Preparation  
# ============================================================================

# TODO: Add rule to prepare DESeq2 dataset using workflow/scripts/prepare_deseq2.R
# This rule will prepare the DESeq2 dataset by filtering lowly expressed genes and normalizing the count data. 
# The output will include an RDS file containing the DESeq2 dataset object and a TSV file with the normalized counts.

rule ea_deseq2:
    input:
        counts= "../results/counts/count_matrix.tsv",
        metadata= "../config/samples.tsv"
    output:
        rds="../results/deseq2/deseq2_dataset.rds",
        normalized="../results/deseq2/normalized_counts.tsv"
    params:
        min_counts=10
    log:
        "../logs/prepare_deseq2.log"
    script:
        "scripts/prepare_deseq2.R"
